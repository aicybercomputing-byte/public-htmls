      "id": "snip-panel-panel-form",
      "section_id": "snip-panel",
      "title": "data-snip-panel + data-snip-screen + data-snip-go + data-snip-validate + data-snip-reset — live flow",
      "type": "Panel & form",
      "aliases": [
        "form",
